<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Capturing audio for on-device wake-word recognition (single-channel handset mic). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Always-on background listening: a foreground service hosts the wake engine so it keeps hearing
         the wake word while every other app is foreground. FOREGROUND_SERVICE_MICROPHONE (API 34+) is
         harmless on the Portal's API 28/29 and future-proofs the declaration. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Start the wake service on boot so listening works without anyone opening anything (there is
         no launcher icon — this app is headless). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Best-effort: free the single handset-mic slot from com.millennium (the Portal's "Hey Alexa"
         wake detector) so we can own it. Durable ownership comes from `pm disable-user com.millennium`
         in setup.sh. -->
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />

    <!-- Runtime discovery of wake-plugin handlers (apps that respond to ACTION_WAKE). Declared so the
         PackageManager query still resolves under package-visibility filtering on higher target SDKs. -->
    <queries>
        <intent>
            <action android:name="com.portal.wake.action.WAKE" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true">

        <!-- Always-on foreground service hosting the wake engine. No Activity / no launcher: this app
             is intentionally invisible and runs only in the background. -->
        <service
            android:name=".service.WakeService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- On boot, start WakeService (background, no UI). Exported so the system delivers BOOT_COMPLETED. -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <!-- Explicit "start now" trigger used by setup.sh after install (no launcher to tap). -->
                <action android:name="com.portal.wake.action.START" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
