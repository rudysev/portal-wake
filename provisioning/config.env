# portal-wake provisioning configuration. Read by both install.sh and install.ps1.

# The wake app to install and start.
PKG=com.portal.wake
# Exported receiver used to start the headless service (the app has no launcher icon).
RECEIVER=com.portal.wake/.service.BootReceiver
# The "start now" action the installer broadcasts after install.
START_ACTION=com.portal.wake.action.START

# Meta's native "Hey Alexa" wake detector. It runs an always-on listener on the single
# handset mic — the same slot portal-wake needs — so the installer disables it (only if
# present). Uninstall re-enables it. We never touch the Alexa client (falcon).
MILLENNIUM_PKG=com.millennium

# Where the APK comes from:
#   APK_GLOB        - a local APK to install (first match wins). Drop a built APK in apks/
#                     to install it directly instead of downloading.
#   RELEASE_REPO    - GitHub repo whose LATEST release's .apk asset is downloaded when no
#                     local APK is present.
#   RELEASE_APK_URL - pin a specific .apk URL (overrides RELEASE_REPO).
APK_GLOB=apks/*.apk
RELEASE_REPO=rudysev/portal-wake
RELEASE_APK_URL=
